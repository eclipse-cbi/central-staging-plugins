{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "UTC",
  "schedule": [
    "every weekend"
  ],
  "packageRules": [
    {
      "matchDatasources": ["maven"],
      "groupName": "Maven dependencies"
    }
  ],
  "prConcurrentLimit": 3,
  "prHourlyLimit": 0,
  "enabledManagers": ["maven"],
  "maven": {
    "enabled": true
  }
}
